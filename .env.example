# Extended BTRFS Node Exporter configuration
PORT=9198

# Optional: Comma-separated UUIDs to include (empty = all)
# BTRFS_INCLUDE_UUIDS=

# Optional: Comma-separated UUIDs to exclude
# BTRFS_EXCLUDE_UUIDS=

# Bees status directory
BEES_STATUS_DIR=/run/bees

# Enable/disable collector modules (all enabled by default)
# COLLECT_SUBVOLUMES=true
# COLLECT_QGROUPS=true
# COLLECT_COMMIT=true
# COLLECT_REPLACE=true
# COLLECT_BALANCE=true
# COLLECT_SCRUB=true
# COLLECT_DEFRAG=true
# COLLECT_BEES=true
# COLLECT_ORPHANS=true
